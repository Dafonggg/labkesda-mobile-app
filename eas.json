{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://labkesda-backend-production.up.railway.app/api/v1",
        "EXPO_PUBLIC_APP_ENV": "development"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://labkesda-backend-production.up.railway.app/api/v1",
        "EXPO_PUBLIC_APP_ENV": "production"
      }
    }
  }
}
